# Environment Variables for ML Portfolio Projects
# Copy this file to .env and fill in your actual API keys

# Polygon.io API Key (required for asset correlation and volatility forecasting)
# Get your free API key at: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# Optional: Override default parameters for volatility forecasting
# TICKER=NVDA
# DAYS_TO_FETCH=730
# DAYS_TO_SIMULATE=30
# NUM_SIMULATIONS=10000
# RANDOM_SEED=42